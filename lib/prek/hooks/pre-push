#!/usr/bin/env bash
set -euo pipefail
# shellcheck source=../lock.sh
source "$(dirname "$0")/../lock.sh"

_stamp_file="$_wrapix_dir/push-verified"
_head_sha=$(git rev-parse HEAD)

# Second push: stamp valid for current HEAD — consume it and let git push.
if [[ -f "$_stamp_file" ]] && [[ "$(<"$_stamp_file")" == "$_head_sha" ]]; then
    rm -f "$_stamp_file"
    exit 0
fi

_prek_acquire_lock

# Save stdin — git writes ref lines once and hook-impl needs them to
# determine which files changed across the push range.
_stdin=$(cat)

if [[ -z "$_stdin" ]]; then
    exit 0
fi

# Run pre-push hooks via hook-impl (not `prek run`) so the ref range
# from stdin is parsed correctly — same code path git would use, but
# decoupled from the SSH connection.
_hook_dir="$(dirname "$0")"
printf '%s\n' "$_stdin" | prek hook-impl \
    --hook-dir "$_hook_dir" \
    --script-version 4 \
    --hook-type=pre-push \
    -- "$@" \
    9>&- || exit 1

# Tests passed — stamp in case the SSH connection died during tests.
# Exit 0 lets git try the original connection. If it's still alive, the
# push succeeds in one shot. If it's dead, the user re-runs git push
# and the stamp makes it instant.
printf '%s\n' "$_head_sha" > "$_stamp_file"
