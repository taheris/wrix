#!/usr/bin/env bash
set -euo pipefail
# shellcheck source=../lock.sh
source "$(dirname "$0")/../lock.sh"

_stamp_file="$_wrapix_dir/push-verified"
_head_sha=$(git rev-parse HEAD)

# Second push: stamp valid for current HEAD — consume it and let git push.
if [[ -f "$_stamp_file" ]] && [[ "$(<"$_stamp_file")" == "$_head_sha" ]]; then
    rm -f "$_stamp_file"
    exit 0
fi

_prek_acquire_lock

# Parse stdin to extract the push range. Git writes one line per ref:
#   <local ref> <local sha> <remote ref> <remote sha>
_from_ref=""
while IFS=' ' read -r _local_ref _local_sha _remote_ref _remote_sha; do
    if [[ "$_remote_sha" != "0000000000000000000000000000000000000000" ]]; then
        _from_ref="$_remote_sha"
    fi
done

# Run pre-push hooks independently (no SSH connection involved).
# Pass the ref range so file-filtered hooks (integration tests) see all
# files changed across the full push, not just the last commit.
_prek_args=(run --stage pre-push)
if [[ -n "$_from_ref" ]]; then
    _prek_args+=(--from-ref "$_from_ref" --to-ref "$_head_sha")
fi
prek "${_prek_args[@]}" 9>&- || exit 1

# Tests passed — stamp for next push attempt.
printf '%s\n' "$_head_sha" > "$_stamp_file"
echo "prek: tests passed — run 'git push' again." >&2
exit 1
