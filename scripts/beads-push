#!/usr/bin/env bash
# beads-push — bd dolt commit + push to Dolt remote + git push beads branch
#              to the GitHub mirror (if the worktree is reachable).
#
# Safe to call from contexts where the beads git worktree is not mounted
# (e.g. container-side ralph runs): the dolt push still happens, the
# github sync is skipped with a notice.
set -euo pipefail

TMP_FILES=()

cleanup() {
  local path
  for path in "${TMP_FILES[@]}"; do
    rm -f "$path"
  done
}
trap cleanup EXIT

make_tmp_file() {
  local path
  path=$(mktemp)
  TMP_FILES+=("$path")
  printf '%s\n' "$path"
}

skip_loom_managed_clone() {
  # Loom clones push through the driver; publishing here targets the wrong remote and races it.
  if [[ -n "${LOOM_INSIDE:-}" ]]; then
    echo "beads-push: \$LOOM_INSIDE set — loom driver owns publish; skipping" >&2
    exit 0
  fi
}

load_workspace_context() {
  # Peel beads-worktree invocations back to the main workspace where the Dolt socket lives.
  BRANCH="$(grep '^sync-branch:' .beads/config.yaml 2>/dev/null | awk '{print $2}' | tr -d '"' || echo beads)"
  BRANCH="${BRANCH:-beads}"

  # empty-ROOT guard below makes unresolved git roots actionable.
  ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  case "$ROOT" in
    */.git/beads-worktrees/*) ROOT="${ROOT%/.git/beads-worktrees/*}" ;;
  esac

  if [[ -z "$ROOT" ]]; then
    echo "beads-push: cannot resolve a git repository from '$PWD' — run inside a workspace checkout" >&2
    exit 1
  fi

  WT="$ROOT/.git/beads-worktrees/$BRANCH"
  WORKTREE_REMOTE_DIR="$WT/.beads/dolt-remote"
  REMOTE_DIR="$ROOT/.beads/dolt/dolt-remote"
}

repair_dolt_origin_remote() {
  # Host-only: never persist a container-local /workspace remote into shared Beads config.
  if [[ -n "${IS_SANDBOX:-}" || "$ROOT" == /workspace* ]]; then
    return 0
  fi
  if [[ ! -d "$WORKTREE_REMOTE_DIR" ]]; then
    return 0
  fi

  local remote
  remote="file://$WORKTREE_REMOTE_DIR"
  if bd dolt remote list 2>/dev/null | grep -Fq "$remote"; then
    return 0
  fi

  echo "beads-push: repairing Dolt origin remote -> $remote" >&2
  if bd dolt remote list 2>/dev/null | awk '{ print $1 }' | grep -Fxq origin; then
    bd sql "CALL DOLT_REMOTE('remove', 'origin')" >/dev/null
  fi
  bd sql "CALL DOLT_REMOTE('add', 'origin', $(sql_quote "$remote"))" >/dev/null
}

sql_quote() {
  local value="$1"
  value=${value//\'/\'\'}
  printf "'%s'" "$value"
}

disable_auto_export() {
  # Persistent suppression is intentional; explicit bd dolt sync makes JSONL auto-export redundant.
  bd config set export.auto false >/dev/null
}

remote_file_exceeds_threshold() {
  local threshold_bytes threshold_mb sz
  threshold_mb="${BEADS_REMOTE_REBUILD_MB:-50}"
  threshold_bytes=$((threshold_mb * 1024 * 1024))

  [[ -d "$REMOTE_DIR" ]] || return 1
  while IFS= read -r sz; do
    if [[ "$sz" -ge "$threshold_bytes" ]]; then
      return 0
    fi
  done < <(find "$REMOTE_DIR" -type f -exec stat -f '%z' {} + 2>/dev/null \
           || find "$REMOTE_DIR" -type f -printf '%s\n' 2>/dev/null)
  return 1
}

rebuild_remote_if_needed() {
  local threshold_mb
  threshold_mb="${BEADS_REMOTE_REBUILD_MB:-50}"
  if ! remote_file_exceeds_threshold; then
    return 0
  fi

  if ! command -v beads-dolt >/dev/null 2>&1; then
    echo "beads-push: remote file >= ${threshold_mb}MiB but beads-dolt not on PATH — cannot rebuild" >&2
    exit 1
  fi

  echo "beads-push: remote file >= ${threshold_mb}MiB — flattening history + rebuilding remote" >&2
  bd flatten --force
  find "$REMOTE_DIR" -mindepth 1 -delete
  beads-dolt stop || true # best-effort: the Dolt container may already be absent before rebuild.
  beads-dolt start "$ROOT"
  wait_for_rebuilt_socket
}

wait_for_rebuilt_socket() {
  local attempt
  for ((attempt = 0; attempt < 10; attempt++)); do
    [[ -S "$ROOT/.wrix/dolt.sock" ]] && break
    sleep 1
  done
}

is_fast_forward_rejection() {
  local stderr_file="$1"
  grep -qiE 'non-fast-forward|fast-forward|reject|behind|out of date|denied' "$stderr_file"
}

query_affected_ids() {
  bd sql --csv "
    SELECT DISTINCT id FROM (
      SELECT to_id AS id
      FROM dolt_commit_diff_issues
      WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
        AND (from_status IS NULL OR from_status <> to_status)
      UNION
      SELECT to_issue_id AS id
      FROM dolt_commit_diff_labels
      WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
      UNION
      SELECT from_issue_id AS id
      FROM dolt_commit_diff_labels
      WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
    ) AS touched
    WHERE id IS NOT NULL
  " | tail -n +2
}

sql_string_list() {
  local id in_list
  in_list=""
  for id in "$@"; do
    in_list+="'${id//\'/\'\'}',"
  done
  printf '%s\n' "${in_list%,}"
}

snapshot_query_for_ids() {
  local in_list="$1"
  cat <<SQL
    SELECT i.id, i.status,
      COALESCE((SELECT GROUP_CONCAT(label ORDER BY label SEPARATOR ',')
                FROM labels WHERE issue_id = i.id), '') AS labels
    FROM issues i
    WHERE i.id IN (${in_list})
    ORDER BY i.id
SQL
}

pull_with_intent_protection() {
  # On fallback, snapshot local status/label intent and refuse divergent pulls.
  local in_list intent_file post_file snapshot_query
  local -a affected_ids

  mapfile -t affected_ids < <(query_affected_ids)
  if [[ "${#affected_ids[@]}" -eq 0 ]]; then
    bd dolt pull
    bd dolt push "$@"
    return 0
  fi

  in_list=$(sql_string_list "${affected_ids[@]}")
  snapshot_query=$(snapshot_query_for_ids "$in_list")
  intent_file=$(make_tmp_file)
  post_file=$(make_tmp_file)

  bd sql --csv "$snapshot_query" >"$intent_file"
  bd dolt pull
  bd sql --csv "$snapshot_query" >"$post_file"

  if ! diff -q "$intent_file" "$post_file" >/dev/null; then
    echo "beads-push: pull-fallback diverged from local intent on status/labels — refusing to push" >&2
    diff "$intent_file" "$post_file" >&2 || true # best-effort: surface row-level diff for the operator.
    printf 'beads-push: affected issue IDs: %s\n' "${affected_ids[*]}" >&2
    exit 1
  fi

  bd dolt push "$@"
}

sync_dolt_remote() {
  # Push before pull so local commits become the merge base for any fallback merge.
  local push_rc push_stderr
  commit_dolt_changes

  push_stderr=$(make_tmp_file)
  push_rc=0
  bd dolt push "$@" 2>"$push_stderr" || push_rc=$?
  cat "$push_stderr" >&2

  if [[ "$push_rc" -eq 0 ]]; then
    return 0
  fi
  if ! is_fast_forward_rejection "$push_stderr"; then
    exit "$push_rc"
  fi

  pull_with_intent_protection "$@"
}

commit_dolt_changes() {
  bd dolt commit || true # best-effort: no-op when there are no pending writes.
}

ensure_beads_worktree() {
    # Recreate absent or dangling beads worktrees relative to the current workspace root.
    if [[ -d "$WT" ]] && git -C "$WT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return 0
    fi

    if [[ -d "$WT" ]]; then
        git worktree prune
        rm -rf "$WT"
    fi
    if git rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
        git worktree add "$WT" "$BRANCH" --quiet
    elif git rev-parse --verify "origin/$BRANCH" >/dev/null 2>&1; then
        git worktree add "$WT" "origin/$BRANCH" --quiet
    else
        echo "beads-push: no '$BRANCH' branch found — skipping github sync" >&2
        exit 0
    fi
}

sync_beads_git_branch() {
    skip_prek_for_beads_branch
    ensure_beads_worktree
    fix_worktree_pointers

    cd "$WT"
    commit_dirty_worktree
    git pull --rebase --quiet

    if [[ -d "$REMOTE_DIR" ]]; then
        rsync -a --delete "$REMOTE_DIR/" "$WT/.beads/dolt-remote/"
    fi

    commit_dirty_worktree
    git push -u origin "$BRANCH" --quiet
    echo "beads-push: synced to GitHub"
}

skip_prek_for_beads_branch() {
    export PREK_ALLOW_NO_CONFIG=1
}

fix_worktree_pointers() {
    # Container checkouts can see host-side absolute gitdir pointers that need rewriting.
    local current wt_gitdir
    wt_gitdir="$ROOT/.git/worktrees/$BRANCH"
    if [[ ! -f "$WT/.git" ]]; then
        return 0
    fi

    current=$(sed 's/^gitdir: //' "$WT/.git")
    if [[ ! -d "$current" && -d "$wt_gitdir" ]]; then
        printf 'gitdir: %s\n' "$wt_gitdir" >"$WT/.git"
        printf '%s/.git\n' "$WT" >"$wt_gitdir/gitdir"
    fi
}

commit_dirty_worktree() {
    git update-index --refresh >/dev/null || true # expected: refresh returns 1 when it flushes stale stat entries.
    if [[ -n "$(git status --porcelain --untracked-files=normal)" ]]; then
        git add -A
        git commit -m "bd sync" --quiet
    fi
}

main() {
  skip_loom_managed_clone
  load_workspace_context
  repair_dolt_origin_remote
  disable_auto_export
  rebuild_remote_if_needed
  sync_dolt_remote "$@"
  sync_beads_git_branch
}

main "$@"
