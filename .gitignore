.cache/
.claude/
.direnv/
.gc/
# Root-level `.wrapix/`: ignore runtime state (logs, scratch, state DB),
# but track the repo-owned `LoomConfig` at `.wrapix/loom/config.toml`.
# See specs/loom-harness.md § Configuration.
/.wrapix/*
!/.wrapix/loom/
/.wrapix/loom/*
!/.wrapix/loom/config.toml
/.wrapix/ralph/runtime/

# Nested `.wrapix/` directories (test-driven; never repo-owned).
**/loom/.wrapix/
**/city/.wrapix/
city.toml
result
result-*
target/

# Beads / Dolt files (added by bd init)
.beads-credential-key
.beads/formulas/
.beads/hooks/
.dolt/
*.db

# Gas City scaffold (gc start creates these at workspace root)
/.runtime/
/formulas/
/hooks/
/orders/
/prompts/

# Gas City pack symlinks (gc start creates these in scripts/)
scripts/cross-rig-deps.sh
scripts/gate-sweep.sh
scripts/jsonl-export.sh
scripts/orphan-sweep.sh
scripts/prune-branches.sh
scripts/reaper.sh
scripts/runtime.sh
scripts/spawn-storm-detect.sh
scripts/wisp-compact.sh
